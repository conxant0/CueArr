{
  "manifest_version": 3,
  "name": "QR Link Scanner",
  "version": "1.0.0",
  "description": "Detect QR codes on the current tab and inject clickable link overlays.",
  "permissions": ["activeTab", "offscreen", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Scan for QR codes"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+Q"
      },
      "description": "Scan for QR codes"
    }
  }
}
